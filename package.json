{
  "name": "@dremchee/uframe",
  "type": "module",
  "version": "0.2.0",
  "packageManager": "pnpm@9.10.0",
  "description": "Embeddable block-based page editor with a framework-agnostic iframe client and Vue library.",
  "homepage": "https://uframe-app.netlify.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dremchee/uframe-app.git"
  },
  "bugs": {
    "url": "https://github.com/dremchee/uframe-app/issues"
  },
  "keywords": [
    "editor",
    "page-builder",
    "vue",
    "visual-editor"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./blocks": {
      "types": "./dist/blocks.d.ts",
      "import": "./dist/blocks.js",
      "require": "./dist/blocks.cjs"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js",
      "require": "./dist/ui.cjs"
    },
    "./i18n/de": {
      "types": "./dist/i18n/de.d.ts",
      "import": "./dist/i18n/de.js",
      "require": "./dist/i18n/de.cjs"
    },
    "./i18n/es": {
      "types": "./dist/i18n/es.d.ts",
      "import": "./dist/i18n/es.js",
      "require": "./dist/i18n/es.cjs"
    },
    "./i18n/fr": {
      "types": "./dist/i18n/fr.d.ts",
      "import": "./dist/i18n/fr.js",
      "require": "./dist/i18n/fr.cjs"
    },
    "./i18n/ja": {
      "types": "./dist/i18n/ja.d.ts",
      "import": "./dist/i18n/ja.js",
      "require": "./dist/i18n/ja.cjs"
    },
    "./i18n/pt-br": {
      "types": "./dist/i18n/pt-br.d.ts",
      "import": "./dist/i18n/pt-br.js",
      "require": "./dist/i18n/pt-br.cjs"
    },
    "./i18n/ru": {
      "types": "./dist/i18n/ru.d.ts",
      "import": "./dist/i18n/ru.js",
      "require": "./dist/i18n/ru.cjs"
    },
    "./i18n/zh-cn": {
      "types": "./dist/i18n/zh-cn.d.ts",
      "import": "./dist/i18n/zh-cn.js",
      "require": "./dist/i18n/zh-cn.cjs"
    },
    "./plugins/ai": {
      "types": "./dist/plugins/ai.d.ts",
      "import": "./dist/plugins/ai.js",
      "require": "./dist/plugins/ai.cjs"
    },
    "./embed": {
      "types": "./dist/embed.d.ts",
      "import": "./dist/embed.js",
      "require": "./dist/embed.cjs"
    },
    "./integrations/vite": {
      "types": "./dist/integrations/vite.d.ts",
      "import": "./dist/integrations/vite.js",
      "require": "./dist/integrations/vite.cjs"
    },
    "./styles/page-frame": {
      "types": "./dist/styles/page-frame.d.ts",
      "import": "./dist/styles/page-frame.js",
      "require": "./dist/styles/page-frame.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "dev:embed": "vite --config vite.config.embed.ts --host 127.0.0.1 --port 5174 --strictPort",
    "dev:lib": "tsdown --watch --no-clean",
    "build": "npm run typecheck && npm run build:lib && npm run build:playground && npm run build:embed",
    "build:lib": "tsdown && tailwindcss -i src/styles/editor.css -o dist/styles.css --minify",
    "build:playground": "vite build",
    "build:embed": "vite build --config vite.config.embed.ts",
    "prepack": "pnpm build:lib",
    "release:npm": "npm publish --access public",
    "typecheck": "vue-tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "preview": "vite preview",
    "docs:api": "typedoc",
    "docs:embed": "npm run build:embed && rm -rf docs/public/embed && mkdir -p docs/public && cp -R build/embed docs/public/embed",
    "docs:dev": "npm run docs:embed && npm run docs:api && vitepress dev docs",
    "docs:build": "npm run docs:embed && npm run docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "review:plan": "plannotator annotate ../docs/plans/page-editor-plan.md",
    "review:changes": "plannotator review",
    "review:sessions": "plannotator sessions --open"
  },
  "peerDependencies": {
    "@vueuse/core": "^14.3.0",
    "vue": "^3.5.34",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.8.1",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lucide/vue": "^1.16.0",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "csstype": "^3.2.3",
    "culori": "^4.0.2",
    "reka-ui": "^2.9.8",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@tailwindcss/cli": "^4.3.0",
    "@tsdown/css": "^0.22.1",
    "@types/culori": "^4.0.1",
    "@types/node": "^24.12.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/compiler-sfc": "3.5.35",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.3.0",
    "eslint": "^10.4.1",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "tsdown": "^0.22.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-vitepress-theme": "^1.1.3",
    "typescript": "~6.0.2",
    "unplugin-vue": "^7.2.0",
    "vite": "^8.0.12",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.7",
    "vue": "^3.5.34",
    "vue-tsc": "^3.2.8",
    "zod": "^4.4.3"
  }
}
